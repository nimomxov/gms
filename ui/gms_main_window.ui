QMainWindow{background-color:#1B1F24;color:#E0E4EA;font-family:&quot;Segoe UI&quot;,&quot;Inter&quot;,sans-serif;font-size:13px;}
QWidget{background-color:transparent;color:#E0E4EA;font-family:&quot;Segoe UI&quot;,&quot;Inter&quot;,sans-serif;}
QFrame{border:none;background-color:transparent;}
QFrame#sidebarFrame,QFrame#inspectorFrame{background-color:#20252B;}
QFrame#cardFrame{background-color:#252B33;border:1px solid #2E343D;border-radius:6px;}
QFrame#dropZoneFrame{background-color:#1E2329;border:2px dashed #3A424D;border-radius:10px;}
QFrame#dropZoneFrame:hover{border-color:#2D9CFF;background-color:#1A2535;}
QScrollArea{background-color:transparent;border:none;}
QScrollArea&gt;QWidget&gt;QWidget{background-color:transparent;}
QScrollBar:vertical{background:#1B1F24;width:8px;border-radius:4px;margin:0;}
QScrollBar::handle:vertical{background:#3A424D;border-radius:4px;min-height:30px;}
QScrollBar::handle:vertical:hover{background:#4A5460;}
QScrollBar::add-line:vertical,QScrollBar::sub-line:vertical{height:0;}
QScrollBar:horizontal{background:#1B1F24;height:8px;border-radius:4px;}
QScrollBar::handle:horizontal{background:#3A424D;border-radius:4px;min-width:30px;}
QScrollBar::handle:horizontal:hover{background:#4A5460;}
QScrollBar::add-line:horizontal,QScrollBar::sub-line:horizontal{width:0;}
QPushButton{background-color:#2A3040;color:#C8CDD5;border:1px solid #3A424D;border-radius:6px;padding:7px 14px;font-size:12px;font-weight:500;}
QPushButton:hover{background-color:#333B48;border-color:#4A5568;color:#FFF;}
QPushButton:pressed{background-color:#252B33;}
QPushButton:disabled{background-color:#1E2228;color:#4A5460;border-color:#2A2F38;}
QPushButton#btnOpenCSV{background-color:#2D9CFF;color:#FFF;border:none;border-radius:8px;font-size:15px;font-weight:700;padding:18px 24px;letter-spacing:0.5px;}
QPushButton#btnOpenCSV:hover{background-color:#3AABFF;}
QPushButton#btnOpenCSV:pressed{background-color:#1F8AEE;}
QPushButton#sidebarFrame QPushButton{background-color:transparent;border:1px solid transparent;border-radius:6px;padding:8px 12px;text-align:left;font-size:12px;color:#9CA3AF;}
QPushButton#sidebarFrame QPushButton:hover{background-color:#2A3040;color:#E0E4EA;}
QPushButton#sidebarFrame QPushButton:checked{background-color:rgba(45,156,255,0.13);border-color:rgba(45,156,255,0.27);color:#2D9CFF;}
QToolButton{background-color:transparent;border:1px solid transparent;border-radius:5px;padding:5px 8px;color:#9CA3AF;font-size:12px;}
QToolButton:hover{background-color:#2A3040;color:#E0E4EA;}
QToolButton:checked{background-color:rgba(45,156,255,0.13);border-color:rgba(45,156,255,0.27);color:#2D9CFF;}
QToolButton::menu-indicator{image:none;}
QTabWidget::pane{border:none;background-color:#1B1F24;top:-1px;}
QTabBar::tab{background-color:#20252B;color:#6B7280;border:1px solid #2E343D;border-bottom:none;padding:10px 20px;margin-right:2px;border-top-left-radius:8px;border-top-right-radius:8px;font-size:12px;font-weight:600;letter-spacing:0.3px;}
QTabBar::tab:hover{background-color:#282E36;color:#C8CDD5;}
QTabBar::tab:selected{background-color:#1B1F24;color:#2D9CFF;border-bottom:2px solid #2D9CFF;}
QTabWidget#subTabs QTabBar::tab{padding:6px 14px;font-size:11px;border-radius:4px;border:1px solid transparent;background-color:transparent;}
QTabWidget#subTabs QTabBar::tab:selected{background-color:rgba(45,156,255,0.13);border-color:rgba(45,156,255,0.27);color:#2D9CFF;}
QTabWidget#subTabs::pane{border:none;background:transparent;}
QGroupBox{background-color:#252B33;border:1px solid #2E343D;border-radius:6px;margin-top:14px;padding:16px 12px 12px 12px;font-weight:600;font-size:12px;color:#9CA3AF;}
QGroupBox::title{subcontrol-origin:margin;subcontrol-position:top left;padding:2px 10px;background-color:#252B33;border-radius:3px;color:#2D9CFF;font-size:11px;letter-spacing:0.5px;text-transform:uppercase;}
QLabel{background:transparent;color:#C8CDD5;border:none;padding:0;}
QLabel#sectionLabel{font-size:11px;font-weight:700;color:#6B7280;letter-spacing:1.0px;text-transform:uppercase;padding:8px 0 4px 0;}
QLabel#dropZoneLabel{font-size:20px;font-weight:600;color:#4A5568;}
QLabel#dropZoneSubLabel{font-size:12px;color:#3A424D;}
QLabel#badgeLabel{background-color:#2A3040;border:1px solid #3A424D;border-radius:4px;padding:3px 8px;font-size:10px;font-weight:700;color:#9CA3AF;}
QLabel#gradeLabel{background-color:rgba(61,220,151,0.13);border:1px solid rgba(61,220,151,0.27);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:700;color:#3DDC97;}
QLabel#warningBadge{background-color:rgba(255,159,67,0.13);border:1px solid rgba(255,159,67,0.27);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:700;color:#FF9F43;}
QLabel#errorBadge{background-color:rgba(255,77,77,0.13);border:1px solid rgba(255,77,77,0.27);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:700;color:#FF4D4D;}
QLabel#valueLabel{font-size:22px;font-weight:700;color:#FFF;}
QLabel#metricLabel{font-size:11px;color:#6B7280;}
QLineEdit{background-color:#1B1F24;border:1px solid #2E343D;border-radius:5px;padding:7px 10px;color:#E0E4EA;font-size:12px;selection-background-color:rgba(45,156,255,0.27);selection-color:#FFF;}
QLineEdit:focus{border-color:#2D9CFF;}
QLineEdit:disabled{background-color:#1A1D22;color:#3A424D;border-color:#252830;}
QLineEdit::placeholder{color:#4A5460;}
QSpinBox,QDoubleSpinBox{background-color:#1B1F24;border:1px solid #2E343D;border-radius:5px;padding:5px 8px;color:#E0E4EA;font-size:12px;min-height:24px;}
QSpinBox:focus,QDoubleSpinBox:focus{border-color:#2D9CFF;}
QSpinBox::up-button,QDoubleSpinBox::up-button,QSpinBox::down-button,QDoubleSpinBox::down-button{background-color:#2A3040;border:none;width:18px;}
QSpinBox::up-button:hover,QDoubleSpinBox::up-button:hover,QSpinBox::down-button:hover,QDoubleSpinBox::down-button:hover{background-color:#333B48;}
QSpinBox::up-arrow,QDoubleSpinBox::up-arrow{image:none;border-left:4px solid transparent;border-right:4px solid transparent;border-bottom:5px solid #9CA3AF;width:0;height:0;}
QSpinBox::down-arrow,QDoubleSpinBox::down-arrow{image:none;border-left:4px solid transparent;border-right:4px solid transparent;border-top:5px solid #9CA3AF;width:0;height:0;}
QComboBox{background-color:#1B1F24;border:1px solid #2E343D;border-radius:5px;padding:6px 10px;color:#E0E4EA;font-size:12px;min-height:24px;}
QComboBox:focus{border-color:#2D9CFF;}
QComboBox::drop-down{border:none;width:24px;padding-right:6px;}
QComboBox::down-arrow{image:none;border-left:4px solid transparent;border-right:4px solid transparent;border-top:5px solid #6B7280;width:0;height:0;}
QComboBox QAbstractItemView{background-color:#252B33;border:1px solid #2E343D;border-radius:5px;color:#E0E4EA;selection-background-color:rgba(45,156,255,0.2);selection-color:#2D9CFF;padding:4px;outline:none;}
QComboBox:disabled{background-color:#1A1D22;color:#3A424D;}
QSlider::groove:horizontal{background:#2E343D;height:4px;border-radius:2px;}
QSlider::handle:horizontal{background:#2D9CFF;width:16px;height:16px;margin:-6px 0;border-radius:8px;border:2px solid #1B1F24;}
QSlider::handle:horizontal:hover{background:#3AABFF;}
QSlider::sub-page:horizontal{background:rgba(45,156,255,0.27);border-radius:2px;}
QCheckBox{color:#C8CDD5;font-size:12px;spacing:8px;}
QCheckBox::indicator{width:18px;height:18px;border-radius:4px;border:2px solid #3A424D;background-color:#1B1F24;}
QCheckBox::indicator:hover{border-color:#4A5568;}
QCheckBox::indicator:checked{background-color:#2D9CFF;border-color:#2D9CFF;}
QCheckBox::indicator:disabled{background-color:#1A1D22;border-color:#252830;}
QRadioButton{color:#C8CDD5;font-size:12px;spacing:8px;}
QRadioButton::indicator{width:18px;height:18px;border-radius:9px;border:2px solid #3A424D;background-color:#1B1F24;}
QRadioButton::indicator:hover{border-color:#4A5568;}
QRadioButton::indicator:checked{border-color:#2D9CFF;background-color:#1B1F24;border-width:4px;}
QTableView,QTableWidget{background-color:#1B1F24;alternate-background-color:#1E2329;border:1px solid #2E343D;border-radius:6px;gridline-color:#252B33;color:#C8CDD5;font-size:11px;selection-background-color:rgba(45,156,255,0.13);selection-color:#2D9CFF;outline:none;}
QTableView::item,QTableWidget::item{padding:4px 8px;border-bottom:1px solid #252B33;}
QTableView::item:hover,QTableWidget::item:hover{background-color:#252B33;}
QHeaderView::section{background-color:#20252B;color:#6B7280;border:none;border-right:1px solid #2E343D;border-bottom:1px solid #2E343D;padding:8px 10px;font-size:11px;font-weight:700;letter-spacing:0.3px;text-transform:uppercase;}
QHeaderView::section:first{border-top-left-radius:6px;}
QHeaderView::section:last{border-top-right-radius:6px;}
QProgressBar{background-color:#1B1F24;border:1px solid #2E343D;border-radius:4px;height:6px;text-align:center;color:transparent;}
QProgressBar::chunk{background:qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #2D9CFF,stop:1 #3AABFF);border-radius:3px;}
QSplitter::handle{background-color:#2E343D;width:1px;}
QSplitter::handle:hover{background-color:#2D9CFF;}
QSplitter::handle:vertical{height:1px;}
QStatusBar{background-color:#171B20;border-top:1px solid #2E343D;color:#6B7280;font-size:11px;padding:2px 8px;}
QStatusBar::item{border:none;}
QStatusBar QLabel{color:#6B7280;font-size:11px;padding:0 8px;}
QMenuBar{background-color:#171B20;border-bottom:1px solid #2E343D;color:#9CA3AF;font-size:12px;padding:2px;}
QMenuBar::item{padding:6px 12px;border-radius:4px;}
QMenuBar::item:hover,QMenuBar::item:selected{background-color:#252B33;color:#E0E4EA;}
QMenu{background-color:#252B33;border:1px solid #2E343D;border-radius:6px;padding:6px;color:#C8CDD5;}
QMenu::item{padding:7px 30px 7px 14px;border-radius:4px;font-size:12px;}
QMenu::item:hover{background-color:rgba(45,156,255,0.13);color:#2D9CFF;}
QMenu::item:disabled{color:#3A424D;}
QMenu::separator{height:1px;background-color:#2E343D;margin:4px 8px;}
QTextEdit,QPlainTextEdit{background-color:#1B1F24;border:1px solid #2E343D;border-radius:6px;color:#C8CDD5;font-family:&quot;Cascadia Code&quot;,&quot;Fira Code&quot;,&quot;Consolas&quot;,monospace;font-size:11px;padding:8px;}
QListWidget{background-color:#1B1F24;border:1px solid #2E343D;border-radius:6px;color:#C8CDD5;font-size:12px;outline:none;padding:4px;}
QListWidget::item{padding:6px 10px;border-radius:4px;}
QListWidget::item:hover{background-color:#252B33;}
QListWidget::item:selected{background-color:rgba(45,156,255,0.13);color:#2D9CFF;}
QTreeWidget{background-color:#1B1F24;border:1px solid #2E343D;border-radius:6px;color:#C8CDD5;font-size:12px;outline:none;}
QTreeWidget::item{padding:4px 6px;border-bottom:1px solid #252B33;}
QTreeWidget::item:hover{background-color:#252B33;}
QTreeWidget::item:selected{background-color:rgba(45,156,255,0.13);color:#2D9CFF;}
QToolTip{background-color:#252B33;color:#E0E4EA;border:1px solid #3A424D;border-radius:5px;padding:6px 10px;font-size:11px;}
QFrame#viewer3dFrame{background-color:#14171C;border:1px solid #2E343D;border-radius:8px;}
QFrame#plotFrame{background-color:#14171C;border:1px solid #2E343D;border-radius:6px;}
QFrame#hSeparator{background-color:#2E343D;max-height:1px;}
